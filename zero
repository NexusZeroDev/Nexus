-- Handle Character Respawn (Fixes Bug where script stops on death)
local function SetupCharacter(char)
	if not char then return end
	local hum = char:WaitForChild("Humanoid", 5)
	local hrp = char:WaitForChild("HumanoidRootPart", 5)
	
	if Settings.AutoFarm or Settings.ChestFarm or Settings.ObservationFarm then -- Updated condition
		-- Re-enable flight if it was on
		local BV = Instance.new("BodyVelocity")
		BV.Name = "FlyVelocity"
		BV.Parent = hrp
		BV.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
		BV.Velocity = Vector3.new(0,0,0)
	end
	
	-- NoClip Loop for this character
	task.spawn(function()
		while char and char.Parent do
			if Settings.AutoFarm or Settings.ChestFarm or Settings.ObservationFarm then -- Updated condition
				for _, part in pairs(char:GetDescendants()) do
					if part:IsA("BasePart") and part.CanCollide then part.CanCollide = false end
				end
			end
			task.wait(0.5)
		end
	end)
end

