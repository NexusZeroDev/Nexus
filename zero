local function CreateTab(name, iconId)
	local Btn = Instance.new("TextButton")
	Btn.Parent = ButtonHolder
	Btn.Size = UDim2.new(1, -20, 0, 35)
	Btn.BackgroundColor3 = Settings.DarkBg
	Btn.BackgroundTransparency = 1
	Btn.Text = "      " .. name
	Btn.TextColor3 = Settings.TextDim
	Btn.Font = Enum.Font.GothamMedium
	Btn.TextSize = 13
	Btn.TextXAlignment = Enum.TextXAlignment.Left
	
	-- Indent fix
	local Indent = Instance.new("UIPadding")
	Indent.Parent = Btn
	Indent.PaddingLeft = UDim.new(0, 20)

	-- Hover Effect
	Btn.MouseEnter:Connect(function()
		TweenService:Create(Btn, TweenInfo.new(0.2), {TextColor3 = Settings.ThemeColor}):Play()
	end)
	Btn.MouseLeave:Connect(function()
		TweenService:Create(Btn, TweenInfo.new(0.2), {TextColor3 = Settings.TextDim}):Play()
	end)
	
	return Btn
end

