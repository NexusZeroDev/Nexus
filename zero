local function DestroyTag(part)
	if part:FindFirstChild("NexaESPNameTag") then
		part.NexaESPNameTag:Destroy()
	end
end

local function UpdateESP()
	if Settings.ESPFruits then
		for _, part in pairs(workspace:GetChildren()) do
			if part.Name:lower():find("fruit") and part:IsA("Model") and part:FindFirstChild("Hitbox") then
				CreateTag(part.Hitbox, part.Name, Color3.fromRGB(255, 255, 0))
			end
		end
	end
	
	if Settings.ESPChests then
		for _, part in pairs(workspace:GetDescendants()) do
			if (part.Name:find("Chest") or part.Name:find("Crate")) and (part:IsA("Part") or part:IsA("Model")) then
				local pos = part:IsA("Model") and part.PrimaryPart.Position or part.Position
				CreateTag(part, part.Name, Color3.fromRGB(0, 255, 0))
			end
		end
	end

	if Settings.ESPEnemies then
		for _, v in pairs(workspace:GetChildren()) do
			if v.Name == "Enemies" then
				for _, enemy in pairs(v:GetChildren()) do
					if enemy:FindFirstChild("HumanoidRootPart") then
						CreateTag(enemy.HumanoidRootPart, enemy.Name, Color3.fromRGB(255, 0, 0))
					end
				end
			end
		end
	end

	if Settings.ESPPlayers then
		for _, player in pairs(Players:GetPlayers()) do
			if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
				CreateTag(player.Character.HumanoidRootPart, player.Name, Color3.fromRGB(0, 150, 255))
			end
		end
	end

	if Settings.ESPNPCs then
		for _, v in pairs(workspace:GetChildren()) do
			if v.Name == "NPCs" then
				for _, npc in pairs(v:GetChildren()) do
					if npc:FindFirstChild("HumanoidRootPart") then
						CreateTag(npc.HumanoidRootPart, npc.Name, Color3.fromRGB(255, 150, 0))
					end
				end
			end
		end
	end
end

local function ClearESP()
	for _, part in pairs(workspace:GetDescendants()) do
		DestroyTag(part)
	end
end

