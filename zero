	SetStatus("Stopped.")
	ScreenGui:Destroy()
end)

task.spawn(function()
	while Running do
		wait(0.5) -- Fast Scan
		if IsHopping then break end
		
		local Fruit = FindFruit()
		if Fruit then
			local FruitName = Fruit.Name
			SetStatus("Found: " .. FruitName)
			Notify("Target: " .. FruitName)
			
			local TargetPart = Fruit:FindFirstChild("Handle") or Fruit:FindFirstChild("Main") or Fruit
			local HRP = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
			
			if HRP and TargetPart then
				-- [[ ATTEMPT TO BRING FRUIT TO CHARACTER (ONCE) ]]
				pcall(function()
					-- Try to set Fruit CFrame to Player
					TargetPart.CFrame = HRP.CFrame
					-- Try to set Network Ownership if possible (hidden logic)
					if TargetPart:IsA("BasePart") then
						sethiddenproperty(TargetPart, "NetworkOwnershipRule", Enum.NetworkOwnership.Manual)
					end
				end)
				task.wait(0.1)

				-- [[ CHECK DISTANCE ]] 
				-- If Bring worked, Distance is 0. If failed (Anchored), Distance is high.
				local Dist = (HRP.Position - TargetPart.Position).Magnitude
				
				if Dist > 10 then
					-- Bring failed (Fruit is Anchored/Server Sided), we MUST tween there
					SetStatus("Flying to Fruit...")
					TweenTo(TargetPart)
				else
					-- Bring worked!
					SetStatus("Fruit Brought!")
				end

				-- Final Collection
				if TargetPart:IsA("BasePart") then
					firetouchinterest(HRP, TargetPart, 0)
					task.wait(0.1)
					firetouchinterest(HRP, TargetPart, 1)
				end
				
				Notify("Processed " .. FruitName)
				task.wait(1) 
			end
		else
			-- NO DELAY - INSTANT HOP
			SetStatus("No Fruits. HOPPING NOW.")
			ServerHop()
		end
	end
end)
