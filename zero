-- Handle Character Respawn (Fixes Bug where script stops on death)
local function SetupCharacter(char)
	if not char then return end
	local hum = char:WaitForChild("Humanoid", 5)
	local hrp = char:WaitForChild("HumanoidRootPart", 5)
	
	if Settings.AutoFarm or Settings.ChestFarm then
		-- Re-enable flight if it was on
		local BV = Instance.new("BodyVelocity")
		BV.Name = "FlyVelocity"
		BV.Parent = hrp
		BV.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
		BV.Velocity = Vector3.new(0,0,0)
	end
	
	-- NoClip Loop for this character
	task.spawn(function()
		while char and char.Parent do
			if Settings.AutoFarm or Settings.ChestFarm then
				for _, part in pairs(char:GetDescendants()) do
					if part:IsA("BasePart") and part.CanCollide then part.CanCollide = false end
				end
			end
			task.wait(0.5)
		end
	end)
end

LocalPlayer.CharacterAdded:Connect(SetupCharacter)
if LocalPlayer.Character then SetupCharacter(LocalPlayer.Character) end

-- Optimized Finder
function GetNearestEnemy()
	local ClosestDist = 1000
	local Target = nil
	-- Optimizing: Assuming "Enemies" folder exists. 
	local Folder = workspace:FindFirstChild("Enemies") or workspace
	
	for _, v in pairs(Folder:GetChildren()) do
		if v:FindFirstChild("Humanoid") and v:FindFirstChild("HumanoidRootPart") and v.Humanoid.Health > 0 then
			local MyPos = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
			if MyPos then
				local Dist = (MyPos.Position - v.HumanoidRootPart.Position).Magnitude
				if Dist < ClosestDist then
					ClosestDist = Dist
					Target = v
				end
			end
		end
	end
	return Target
end

function GetNearestChest()
	local ClosestDist = 99999
	local Target = nil
	local MyPos = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
	
	if not MyPos then return nil end

	-- Optimizing: Only check folders or common locations if possible, but we'll use Descendants safely
	for _, v in pairs(workspace:GetDescendants()) do
		if (v.Name:find("Chest") or v.Name:find("Crate")) and (v:IsA("Part") or v:IsA("Model")) then
			if table.find(Settings.IgnoredChests, v) then continue end
			if v:IsA("Model") and not v.PrimaryPart then continue end
			
			local Pos = v:IsA("Model") and v.PrimaryPart.Position or v.Position
			local Dist = (MyPos.Position - Pos).Magnitude
			
			if Dist < ClosestDist then
				ClosestDist = Dist
				Target = v
			end
		end
	end
	return Target
end

function Attack()
	VirtualInputManager:SendMouseButtonEvent(0, 0, 0, true, game, 1)
	task.wait(0.1)
	VirtualInputManager:SendMouseButtonEvent(0, 0, 0, false, game, 1)
end

-- 6. MAIN LOOPS
local StartTime = tick()

RunService.RenderStepped:Connect(function()
	local Elapsed = tick() - StartTime
	local TimeLeft = math.ceil(Settings.ServerHopDelay - Elapsed)
	TimerLabel.Text = (TimeLeft > 0) and "Server Hop in: " .. math.floor(TimeLeft/60) .. ":" .. (TimeLeft%60) or "HOPPING..."

	-- Safety Check
	local Char = LocalPlayer.Character
	if not Char or not Char:FindFirstChild("HumanoidRootPart") then return end
	local HRP = Char.HumanoidRootPart
	
	-- [[ AUTO FARM ]]
	if Settings.AutoFarm then
		local Tool = Char:FindFirstChildOfClass("Tool") or LocalPlayer.Backpack:FindFirstChildOfClass("Tool")
		if Tool and Tool.Parent == LocalPlayer.Backpack then Tool.Parent = Char end

		local Enemy = GetNearestEnemy()
		if Enemy then
			StatusLabel.Text = "Attacking: " .. Enemy.Name
			local EnemyPos = Enemy.HumanoidRootPart.Position
			-- Look at enemy
			local LookCFrame = CFrame.new(EnemyPos + Vector3.new(0, Settings.FarmDistance, 0), EnemyPos)
			
			HRP.CFrame = HRP.CFrame:Lerp(LookCFrame, Settings.Smoothness)
			HRP.Velocity = Vector3.new(0,0,0) -- Freeze physics
			
			Attack()
		else
			StatusLabel.Text = "Status: Searching for Mobs..."
		end
	end

	-- [[ CHEST FARM ]]
	if Settings.ChestFarm then
		local Chest = GetNearestChest()
		if Chest then
			StatusLabel.Text = "Collecting: " .. Chest.Name
			local ChestPos = Chest:IsA("Model") and Chest.PrimaryPart.Position or Chest.Position
			local Dist = (HRP.Position - ChestPos).Magnitude
			
			if Dist < 6 then
				-- We are close enough
				Char.Humanoid.Jump = true
				table.insert(Settings.IgnoredChests, Chest) -- Don't target this again immediately
				StatusLabel.Text = "Collected! Moving to next..."
				
				-- Clean ignore list occasionally
				task.delay(15, function()
					for i,v in pairs(Settings.IgnoredChests) do
						if v == Chest then table.remove(Settings.IgnoredChests, i) end
					end
				end)
			else
				HRP.CFrame = HRP.CFrame:Lerp(CFrame.new(ChestPos), Settings.Smoothness)
				HRP.Velocity = Vector3.new(0,0,0)
			end
		else
			StatusLabel.Text = "Status: No Chests Found"
		end
	end
end)

-- 7. BUTTON LOGIC
local function ToggleFlight(enable)
	local Char = LocalPlayer.Character
	if not Char or not Char:FindFirstChild("HumanoidRootPart") then return end
	
	if enable then
		local BV = Instance.new("BodyVelocity")
		BV.Name = "FlyVelocity"
		BV.Parent = Char.HumanoidRootPart
		BV.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
		BV.Velocity = Vector3.new(0,0,0)
	else
		if Char.HumanoidRootPart:FindFirstChild("FlyVelocity") then
			Char.HumanoidRootPart.FlyVelocity:Destroy()
		end
	end
end

