-- ============================================================================
--    PART D: SLIDE ANIMATION LOGIC
-- ============================================================================

local function OpenHub()
	-- 1. Slide Top Bar UP (Hidden)
	TweenService:Create(TopBar, TweenInfo.new(0.5, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
		Position = UDim2.new(0.5, -160, 0, -100)
	}):Play()
	
	task.wait(0.2)
	
	-- 2. Slide Main Hub UP (Visible)
	MainContainer.Visible = true
	TweenService:Create(MainContainer, TweenInfo.new(0.6, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
		Position = UDim2.new(0.5, -325, 0.5, -190) -- Center Screen
	}):Play()
end

local function CloseHub()
	-- 1. Slide Main Hub DOWN (Hidden)
	TweenService:Create(MainContainer, TweenInfo.new(0.5, Enum.EasingStyle.Quart, Enum.EasingDirection.In), {
		Position = UDim2.new(0.5, -325, 1.5, 0) -- Below Screen
	}):Play()
	
	task.wait(0.3)
	
	-- 2. Slide Top Bar DOWN (Visible)
	TweenService:Create(TopBar, TweenInfo.new(0.6, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
		Position = UDim2.new(0.5, -160, 0, 15) -- Standard Top Position
	}):Play()
end

local function PlayIntro()
	-- Initial Slide Down
	task.wait(1)
	TweenService:Create(TopBar, TweenInfo.new(1, Enum.EasingStyle.Exponential, Enum.EasingDirection.Out), {
		Position = UDim2.new(0.5, -160, 0, 15)
	}):Play()
end

