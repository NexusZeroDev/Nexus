function ServerHop()
	StatusLabel.Text = "Status: Hopping Server..."
	if queue_on_teleport then
		queue_on_teleport('loadstring(game:HttpGet("https://raw.githubusercontent.com/NexusZeroDev/Nexus/main/zero?v="..tostring(tick())))()')
	end
	
	local PlaceID = game.PlaceId
	local AllIDs = {}
	local foundAnything = ""
	local actualHour = os.date("!*t").hour
	
	local function TPReturner()
		local Site;
		if foundAnything == "" then
			Site = game.HttpService:JSONDecode(game:HttpGet('https://games.roblox.com/v1/games/' .. PlaceID .. '/servers/Public?sortOrder=Asc&limit=100'))
		else
			Site = game.HttpService:JSONDecode(game:HttpGet('https://games.roblox.com/v1/games/' .. PlaceID .. '/servers/Public?sortOrder=Asc&limit=100&cursor=' .. foundAnything))
		end
		
		local ID = ""
		if Site.nextPageCursor and Site.nextPageCursor ~= "null" and Site.nextPageCursor ~= nil then
			foundAnything = Site.nextPageCursor
		end
		
		for i,v in pairs(Site.data) do
			local Possible = true
			ID = tostring(v.id)
			if tonumber(v.maxPlayers) > tonumber(v.playing) then
				for _,Existing in pairs(AllIDs) do
					if ID == tostring(Existing) then Possible = false end
				end
				if Possible == true then
					table.insert(AllIDs, ID)
					wait()
					pcall(function()
						TeleportService:TeleportToPlaceInstance(PlaceID, ID, LocalPlayer)
					end)
					wait(4)
				end
			end
		end
	end
	TPReturner() 
end

function GetNearestEnemy()
	local ClosestDist = 2000
	local Target = nil
	local PotentialTargets = {}
	if workspace:FindFirstChild("Enemies") then
		for _, v in pairs(workspace.Enemies:GetChildren()) do table.insert(PotentialTargets, v) end
	end
	for _, v in pairs(PotentialTargets) do
		if v:FindFirstChild("Humanoid") and v:FindFirstChild("HumanoidRootPart") and v.Humanoid.Health > 0 then
			local Dist = (LocalPlayer.Character.HumanoidRootPart.Position - v.HumanoidRootPart.Position).Magnitude
			if Dist < ClosestDist then
				ClosestDist = Dist
				Target = v
			end
		end
	end
	return Target
end

function GetNearestChest()
	local ClosestDist = 5000
	local Target = nil
	
	for _, v in pairs(workspace:GetDescendants()) do
		-- Blox fruits chests usually named Chest1, Chest2, Chest3
		if string.find(v.Name, "Chest") and (v:IsA("Part") or v:IsA("Model")) then
			if v:IsA("Model") and not v.PrimaryPart then continue end -- Skip broken chests
			
			local Pos = v:IsA("Model") and v.PrimaryPart.Position or v.Position
			local Dist = (LocalPlayer.Character.HumanoidRootPart.Position - Pos).Magnitude
			
			if Dist < ClosestDist then
				ClosestDist = Dist
				Target = v
			end
		end
	end
	return Target
end

function Attack()
	VirtualInputManager:SendMouseButtonEvent(0, 0, 0, true, game, 1)
	task.wait(0.05)
	VirtualInputManager:SendMouseButtonEvent(0, 0, 0, false, game, 1)
end

function FormatTime(seconds)
	local minutes = math.floor(seconds / 60)
	local secs = seconds % 60
	return string.format("%02d:%02d", minutes, secs)
end

local StartTime = tick()

RunService.RenderStepped:Connect(function()
	local Elapsed = tick() - StartTime
	local TimeLeft = math.ceil(Settings.ServerHopDelay - Elapsed)
	
	if TimeLeft <= 0 then
		TimerLabel.Text = "HOPPING NOW..."
		ServerHop()
		StartTime = tick() + 100
	else
		TimerLabel.Text = "Server Hop in: " .. FormatTime(TimeLeft)
	end
	
	-- [[ MOB FARM LOGIC ]]
	if Settings.AutoFarm then
		local Character = LocalPlayer.Character
		if not Character or not Character:FindFirstChild("HumanoidRootPart") then return end
		local HRP = Character.HumanoidRootPart
		
		local Tool = Character:FindFirstChildOfClass("Tool")
		if not Tool then
			for _, item in pairs(LocalPlayer.Backpack:GetChildren()) do
				if item:IsA("Tool") then item.Parent = Character break end
			end
		end

		local Enemy = GetNearestEnemy()
		if Enemy then
			StatusLabel.Text = "Mob: " .. Enemy.Name
			local EnemyPos = Enemy.HumanoidRootPart.Position
			local TargetCFrame = CFrame.new(EnemyPos + Vector3.new(0, Settings.FarmDistance, 0), EnemyPos)
			
			if (HRP.Position - TargetCFrame.Position).Magnitude > 300 then
				HRP.CFrame = TargetCFrame
			else
				HRP.CFrame = HRP.CFrame:Lerp(TargetCFrame, Settings.Smoothness)
			end
			HRP.Velocity = Vector3.new(0,0,0)
			Attack()
		else
			StatusLabel.Text = "Status: No Mobs Found"
		end
	end
	
	-- [[ CHEST FARM LOGIC ]]
	if Settings.ChestFarm then
		local Character = LocalPlayer.Character
		if not Character or not Character:FindFirstChild("HumanoidRootPart") then return end
		local HRP = Character.HumanoidRootPart
		
		local Chest = GetNearestChest()
		if Chest then
			StatusLabel.Text = "Chest: " .. Chest.Name
			local ChestPos = Chest:IsA("Model") and Chest.PrimaryPart.Position or Chest.Position
			
			-- Tween directly into the chest to collect it
			local TargetCFrame = CFrame.new(ChestPos)
			
			if (HRP.Position - TargetCFrame.Position).Magnitude > 300 then
				HRP.CFrame = TargetCFrame
			else
				HRP.CFrame = HRP.CFrame:Lerp(TargetCFrame, Settings.Smoothness)
			end
			HRP.Velocity = Vector3.new(0,0,0)
		else
			StatusLabel.Text = "Status: No Chests Found"
		end
	end
end)

