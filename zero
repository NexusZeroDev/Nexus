		TweenService:Create(TopBar, TweenInfo.new(0.5), {Position=UDim2.new(0.5,-140,0,-100)}):Play()
		task.wait(0.2)
		Main.Visible=true
		TweenService:Create(Main, TweenInfo.new(0.5, Enum.EasingStyle.Back), {Position=UDim2.new(0.5,-220,0.5,-130)}):Play()
	else
		TweenService:Create(Main, TweenInfo.new(0.5), {Position=UDim2.new(0.5,-220,1.5,0)}):Play()
