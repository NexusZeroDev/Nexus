local function CreateStatLine(label, text, order)
	local Lbl = Instance.new("TextLabel")
	Lbl.Parent = ContentArea
	Lbl.BackgroundTransparency = 1
	Lbl.Size = UDim2.new(1, 0, 0, 25)
	Lbl.Position = UDim2.new(0, 0, 0, (order * 30) + 20)
	Lbl.Text = label .. ": "
	Lbl.TextColor3 = Settings.TextDim
	Lbl.Font = Enum.Font.GothamBold
	Lbl.TextSize = 14
	Lbl.TextXAlignment = Enum.TextXAlignment.Left
	
	local Val = Instance.new("TextLabel")
	Val.Parent = Lbl
	Val.BackgroundTransparency = 1
	Val.Size = UDim2.new(1, 0, 1, 0)
	Val.Position = UDim2.new(0, 120, 0, 0) -- Offset
	Val.Text = text
	Val.TextColor3 = Settings.TextColor
	Val.Font = Enum.Font.Gotham
	Val.TextSize = 14
	Val.TextXAlignment = Enum.TextXAlignment.Left
	
	return Val
end

