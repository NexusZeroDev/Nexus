-- 4. ESP LOGIC (UPDATED)
local function RemoveESP()
	for _, v in pairs(workspace:GetDescendants()) do
		if v.Name == "NexaESP" or v.Name == "NexaInfo" then v:Destroy() end
	end
end

local function DrawESP(player)
	if not player.Character then return end
	local Char = player.Character
	local HRP = Char:FindFirstChild("HumanoidRootPart")
	if not HRP then return end
	
	if Char:FindFirstChild("NexaESP") then return end 
	
	-- Faction Logic
	local TeamColor = Color3.fromRGB(200, 200, 200) 
	local FactionText = "Civilian"
	
	if player.Team then
		local tName = string.lower(player.Team.Name)
		if string.find(tName, "pirate") then
			TeamColor = Color3.fromRGB(255, 60, 60)
			FactionText = "Pirate"
		elseif string.find(tName, "marine") then
			TeamColor = Color3.fromRGB(60, 120, 255)
			FactionText = "Marine"
		end
	end
	
	-- Highlight
	local HL = Instance.new("Highlight")
	HL.Name = "NexaESP"
	HL.Parent = Char
	HL.FillColor = TeamColor
	HL.OutlineColor = Color3.new(1,1,1)
	HL.FillTransparency = 0.5
	HL.OutlineTransparency = 0
	
	-- Billboard
	local BG = Instance.new("BillboardGui")
	BG.Name = "NexaInfo"
	BG.Parent = HRP
	BG.Size = UDim2.new(0, 250, 0, 60)
	BG.StudsOffset = Vector3.new(0, 4.5, 0)
	BG.AlwaysOnTop = true
	
	local Info = Instance.new("TextLabel")
	Info.Name = "InfoText"
	Info.Parent = BG
	Info.Size = UDim2.new(1, 0, 1, 0)
	Info.BackgroundTransparency = 1
	Info.Font = Enum.Font.GothamBold
	Info.TextSize = 11
	Info.TextColor3 = TeamColor
	Info.TextStrokeTransparency = 0.5
	Info.Text = "Loading..."
	
	BG:SetAttribute("Faction", FactionText)
end

-- 5. FUNCTIONALITY HANDLERS

local function Notify(msg)
	StarterGui:SetCore("SendNotification", {Title = "NEXA SECURITY", Text = msg, Duration = 5})
end

local function ServerHop()
	local PlaceID = game.PlaceId
	local AllIDs = {}
	local foundAnything = ""
	local function TPReturner()
		local Site;
		if foundAnything == "" then
			Site = game.HttpService:JSONDecode(game:HttpGet('https://games.roblox.com/v1/games/' .. PlaceID .. '/servers/Public?sortOrder=Asc&limit=100'))
		else
			Site = game.HttpService:JSONDecode(game:HttpGet('https://games.roblox.com/v1/games/' .. PlaceID .. '/servers/Public?sortOrder=Asc&limit=100&cursor=' .. foundAnything))
		end
		if Site.nextPageCursor and Site.nextPageCursor ~= "null" and Site.nextPageCursor ~= nil then foundAnything = Site.nextPageCursor end
		for i,v in pairs(Site.data) do
			local Possible = true
			if tonumber(v.maxPlayers) > tonumber(v.playing) then
				for _,Existing in pairs(AllIDs) do if tostring(v.id) == tostring(Existing) then Possible = false end end
				if Possible == true then
					table.insert(AllIDs, tostring(v.id))
					TeleportService:TeleportToPlaceInstance(PlaceID, tostring(v.id), LocalPlayer)
					wait(4)
				end
			end
		end
	end
	pcall(function() TPReturner() end)
end

-- Anti-Ban Logic
local JoinTime = tick()
local Warned25, Warned28 = false, false
task.spawn(function()
	while true do
		task.wait(1)
		if State.AntiBan then
			local Elapsed = tick() - JoinTime
			if Elapsed >= 1500 and not Warned25 then Notify("Security: Server Hop in 5 mins"); Warned25 = true end
			if Elapsed >= 1680 and not Warned28 then Notify("Security: Server Hop in 2 mins"); Warned28 = true end
			if Elapsed >= 1800 then Notify("Security: Hopping Now..."); ServerHop() end
		end
	end
end)

-- 6. RUNTIME LOOPS
RunService.RenderStepped:Connect(function()
	local Char = LocalPlayer.Character
	if not Char then return end
	local Hum = Char:FindFirstChild("Humanoid")
	local HRP = Char:FindFirstChild("HumanoidRootPart")
	
	-- Movement
	if Hum and State.SpeedEnabled then Hum.WalkSpeed = State.SpeedAmt end
	if Hum and State.JumpEnabled then Hum.JumpPower = State.JumpAmt end
	
	-- Water Walk
	if HRP and State.WalkWater then
		local P = workspace:FindFirstChild("NexaPlat") or Instance.new("Part"); P.Name="NexaPlat"; P.Parent=workspace; P.Anchored=true; P.Transparency=1; P.Size=Vector3.new(15,1,15); P.CanCollide=true
		P.CFrame = CFrame.new(HRP.Position.X, -3.5, HRP.Position.Z)
	else
		if workspace:FindFirstChild("NexaPlat") then workspace.NexaPlat:Destroy() end
	end
	
	-- Anti Stun
	if Hum and State.AntiStun then
		Hum:SetStateEnabled(Enum.HumanoidStateType.FallingDown, false)
		Hum:SetStateEnabled(Enum.HumanoidStateType.Ragdoll, false)
		Hum.PlatformStand = false
		Hum.Sit = false
	end
	
	-- Aim Logic
	if (State.AimPlayers or State.AimMobs) and HRP then
		local Target, Dist = nil, 9999
		if State.AimPlayers then
			for _, v in pairs(Players:GetPlayers()) do
				if v ~= LocalPlayer and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
					local d = (v.Character.HumanoidRootPart.Position - HRP.Position).Magnitude
					if d < Dist then Dist = d; Target = v.Character.HumanoidRootPart end
				end
			end
		end
		if State.AimMobs then
			local Mobs = workspace:FindFirstChild("Enemies") or workspace:FindFirstChild("Mobs") or workspace
			for _, v in pairs(Mobs:GetChildren()) do
				if v:FindFirstChild("Humanoid") and v:FindFirstChild("HumanoidRootPart") and v.Humanoid.Health > 0 then
					local d = (v.HumanoidRootPart.Position - HRP.Position).Magnitude
					if d < Dist then Dist = d; Target = v.HumanoidRootPart end
				end
			end
		end
		if Target then Camera.CFrame = CFrame.new(Camera.CFrame.Position, Target.Position) end
	end
	
	-- ESP UPDATE LOOP (WITH LEVEL & PVP)
	if State.ESP then
		for _, p in pairs(Players:GetPlayers()) do
			if p ~= LocalPlayer then
				-- Draw
				if p.Character and not p.Character:FindFirstChild("NexaESP") then DrawESP(p) end
				
				-- Update
				if p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
					local HRP = p.Character.HumanoidRootPart
					local BG = HRP:FindFirstChild("NexaInfo")
					local pHum = p.Character:FindFirstChild("Humanoid")
					
					if BG and BG:FindFirstChild("InfoText") and pHum and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
						local Dist = math.floor((LocalPlayer.Character.HumanoidRootPart.Position - HRP.Position).Magnitude)
						local HP = math.floor((pHum.Health / pHum.MaxHealth) * 100)
						local Fac = BG:GetAttribute("Faction") or "Player"
						
						-- GET LEVEL
						local Level = "?"
						if p:FindFirstChild("Data") and p.Data:FindFirstChild("Level") then
							Level = tostring(p.Data.Level.Value)
						end
						
						-- GET PVP STATUS (ForceField Logic)
						local PvPStatus = "ON"
						if p.Character:FindFirstChildOfClass("ForceField") then
							PvPStatus = "OFF"
						end
						
						-- FINAL TEXT
						BG.InfoText.Text = string.format("[%s] %s [Lvl: %s]\nPvP: %s | HP: %d%% | Dist: %dm", Fac, p.Name, Level, PvPStatus, HP, Dist)
						
						-- Color Logic for PvP
						if PvPStatus == "ON" then
							BG.InfoText.TextColor3 = Color3.fromRGB(255, 50, 50) -- Red alert if PvP ON
						else
							BG.InfoText.TextColor3 = Color3.fromRGB(100, 255, 100) -- Green safe if PvP OFF
						end
					end
				end
			end
		end
	else
		RemoveESP()
	end
end)

