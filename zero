-- 5. FUNCTIONS
local function ApplyBoost()
	-- 1. Save the FPS at the moment of clicking
	initialFPS = currentFPS
	beforeLabel.Text = "Before FPS: " .. initialFPS
	
	-- 2. HDR EFFECT (Color Correction)
	local CC = Instance.new("ColorCorrectionEffect")
	CC.Name = "NexusHDR"
	CC.Saturation = 0.4      -- Make colors pop
	CC.Contrast = 0.2        -- Sharpen image
	CC.Parent = Lighting
	
	local Bloom = Instance.new("BloomEffect")
	Bloom.Name = "NexusBloom"
	Bloom.Intensity = 0.3
	Bloom.Size = 10
	Bloom.Parent = Lighting

	-- 3. FPS BOOST (Lower Quality)
	Lighting.GlobalShadows = false
	Lighting.FogEnd = 9e9
	
	-- Turn all parts into Smooth Plastic (Reduces lag significantly)
	for _, v in pairs(workspace:GetDescendants()) do
		if v:IsA("BasePart") and v.Material ~= Enum.Material.SmoothPlastic then
			v.Material = Enum.Material.SmoothPlastic
			v.CastShadow = false
		elseif v:IsA("Texture") or v:IsA("Decal") then
			v.Transparency = 1 -- Hide textures
		end
	end
end

local function RemoveBoost()
	-- It is hard to fully "undo" a texture deletion without rejoining,
	-- but we can remove the HDR effects.
	if Lighting:FindFirstChild("NexusHDR") then Lighting.NexusHDR:Destroy() end
	if Lighting:FindFirstChild("NexusBloom") then Lighting.NexusBloom:Destroy() end
	Lighting.GlobalShadows = true
end

-- 6. BUTTON LOGIC
button.MouseButton1Click:Connect(function()
	isOn = not isOn
	
	if isOn then
		button.Text = "BOOST ACTIVE"
		button.BackgroundColor3 = Color3.fromRGB(0, 200, 100)
		ApplyBoost()
	else
		button.Text = "BOOST OFF"
		button.BackgroundColor3 = Color3.fromRGB(255, 60, 60)
		RemoveBoost()
	end
end)
