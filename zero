end

local function GetClosestTarget()
	local Closest = nil
	local MaxDist = Settings.FOV
	local MousePos = Vector2.new(Mouse.X, Mouse.Y)

	local Candidates = {}

	-- Collect Players
	if State.SilentPlayers then
		for _, p in pairs(Players:GetPlayers()) do
			if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
				table.insert(Candidates, p.Character)
			end
		end
	end

	-- Collect Mobs
	if State.SilentMobs then
		local Mobs = workspace:FindFirstChild("Enemies") or workspace:FindFirstChild("Mobs") or workspace
		for _, m in pairs(Mobs:GetChildren()) do
			if m:FindFirstChild("Humanoid") and m:FindFirstChild("HumanoidRootPart") and m.Humanoid.Health > 0 then
				table.insert(Candidates, m)
			end
		end
	end

	-- Calculate closest to Mouse
	for _, target in pairs(Candidates) do
		local HRP = target:FindFirstChild("HumanoidRootPart")
		if HRP then
			local ScreenPos, OnScreen = Camera:WorldToViewportPoint(HRP.Position)
			if OnScreen then
				local Dist = (Vector2.new(ScreenPos.X, ScreenPos.Y) - MousePos).Magnitude
				if Dist < MaxDist then
					MaxDist = Dist
					Closest = HRP
				end
			end
		end
	end
	
	return Closest
end

-- 5. RUNTIME LOOPS
RunService.RenderStepped:Connect(function()
	local Char = LocalPlayer.Character
	if not Char then return end
	local Hum = Char:FindFirstChild("Humanoid")
	local HRP = Char:FindFirstChild("HumanoidRootPart")
	
	-- [Silent Aim Logic]
	if State.SilentAim and (State.SilentPlayers or State.SilentMobs) then
		local Target = GetClosestTarget()
		if Target then
			-- If mouse clicked, force camera/hit
			if UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton1) then
				Camera.CFrame = CFrame.new(Camera.CFrame.Position, Target.Position)
			end
		end
	end

	-- [Movement]
	if Hum and State.SpeedEnabled then Hum.WalkSpeed = State.SpeedAmt end
	if Hum and State.JumpEnabled then Hum.JumpPower = State.JumpAmt end
	
	-- [Water Walk]
	if HRP and State.WalkWater then
		local P = workspace:FindFirstChild("NexaPlat") or Instance.new("Part"); P.Name="NexaPlat"; P.Parent=workspace; P.Anchored=true; P.Transparency=1; P.Size=Vector3.new(15,1,15); P.CanCollide=true
		P.CFrame = CFrame.new(HRP.Position.X, -3.5, HRP.Position.Z)
	else
		if workspace:FindFirstChild("NexaPlat") then workspace.NexaPlat:Destroy() end
	end
	
	-- [Anti Stun]
	if Hum and State.AntiStun then
		Hum:SetStateEnabled(Enum.HumanoidStateType.FallingDown, false)
		Hum:SetStateEnabled(Enum.HumanoidStateType.Ragdoll, false)
		Hum.PlatformStand = false; Hum.Sit = false
	end
end)

