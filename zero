local function Notify(msg)
	StarterGui:SetCore("SendNotification", {Title = "NEXA SECURITY", Text = msg, Duration = 5})
end

local function ServerHop()
	local PlaceID = game.PlaceId
	local AllIDs = {}
	local foundAnything = ""
	local function TPReturner()
		local Site;
		if foundAnything == "" then
			Site = game.HttpService:JSONDecode(game:HttpGet('https://games.roblox.com/v1/games/' .. PlaceID .. '/servers/Public?sortOrder=Asc&limit=100'))
		else
			Site = game.HttpService:JSONDecode(game:HttpGet('https://games.roblox.com/v1/games/' .. PlaceID .. '/servers/Public?sortOrder=Asc&limit=100&cursor=' .. foundAnything))
		end
		if Site.nextPageCursor and Site.nextPageCursor ~= "null" and Site.nextPageCursor ~= nil then foundAnything = Site.nextPageCursor end
		for i,v in pairs(Site.data) do
			local Possible = true
			if tonumber(v.maxPlayers) > tonumber(v.playing) then
				for _,Existing in pairs(AllIDs) do if tostring(v.id) == tostring(Existing) then Possible = false end end
				if Possible == true then
					table.insert(AllIDs, tostring(v.id))
					TeleportService:TeleportToPlaceInstance(PlaceID, tostring(v.id), LocalPlayer)
					wait(4)
				end
			end
		end
	end
	pcall(function() TPReturner() end)
end

-- 5. FUNCTIONALITY HANDLERS

-- Jump Ball Logic
local BallPart = nil
local function UpdateJumpBall()
	if State.JumpBall then
		if not BallPart then
			BallPart = Instance.new("Part")
			BallPart.Name = "NexaJumpBall"
			BallPart.Shape = Enum.PartType.Ball
			BallPart.Size = Vector3.new(4,4,4)
			BallPart.Material = Enum.Material.Neon
			BallPart.Color = Settings.Theme
			BallPart.Parent = workspace
			-- Spawn in front
			if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
				BallPart.Position = LocalPlayer.Character.HumanoidRootPart.Position + Vector3.new(5, 5, 0)
			end
			-- Physics properties
			BallPart.CustomPhysicalProperties = PhysicalProperties.new(0.7, 0.3, 0.5, 1, 1) -- Friction so it rolls but stops
			
			BallPart.Touched:Connect(function(hit)
				if hit.Parent == LocalPlayer.Character then
					local Hum = LocalPlayer.Character:FindFirstChild("Humanoid")
					if Hum then
						Hum.JumpPower = 300 -- SUPER JUMP
						Hum.Jump = true
						task.wait(0.5)
						Hum.JumpPower = State.JumpAmt -- Reset
					end
				end
			end)
		end
	else
		if BallPart then BallPart:Destroy(); BallPart = nil end
	end
end

-- Anti-Ban Logic
local JoinTime = tick()
local Warned25, Warned28 = false, false
task.spawn(function()
	while true do
		task.wait(1)
		if State.AntiBan then
			local Elapsed = tick() - JoinTime
			if Elapsed >= 1500 and not Warned25 then Notify("Security: Server Hop in 5 mins"); Warned25 = true end
			if Elapsed >= 1680 and not Warned28 then Notify("Security: Server Hop in 2 mins"); Warned28 = true end
			if Elapsed >= 1800 then 
				Notify("Security: Hopping Now...")
				ServerHop() 
			end
		end
	end
end)

-- 6. RUNTIME LOOPS
RunService.RenderStepped:Connect(function()
	local Char = LocalPlayer.Character
	if not Char then return end
	local Hum = Char:FindFirstChild("Humanoid")
	local HRP = Char:FindFirstChild("HumanoidRootPart")
	
	-- Movement
	if Hum and State.SpeedEnabled then Hum.WalkSpeed = State.SpeedAmt end
	if Hum and State.JumpEnabled then Hum.JumpPower = State.JumpAmt end
	
	-- Water Walk
	if HRP and State.WalkWater then
		local P = workspace:FindFirstChild("NexaPlat") or Instance.new("Part"); P.Name="NexaPlat"; P.Parent=workspace; P.Anchored=true; P.Transparency=1; P.Size=Vector3.new(15,1,15); P.CanCollide=true
		P.CFrame = CFrame.new(HRP.Position.X, -3.5, HRP.Position.Z)
	else
		if workspace:FindFirstChild("NexaPlat") then workspace.NexaPlat:Destroy() end
	end
	
	-- Anti Stun (Improved)
	if Hum and State.AntiStun then
		Hum:SetStateEnabled(Enum.HumanoidStateType.FallingDown, false)
		Hum:SetStateEnabled(Enum.HumanoidStateType.Ragdoll, false)
		Hum.PlatformStand = false
		Hum.Sit = false
	end
	
	-- Aim Logic (Split)
	if (State.AimPlayers or State.AimMobs) and HRP then
		local Target, Dist = nil, 9999
		local Folder = nil
		
		if State.AimPlayers then Folder = Players:GetPlayers() end
		
		-- Check Players
		if State.AimPlayers then
			for _, v in pairs(Players:GetPlayers()) do
				if v ~= LocalPlayer and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
					local d = (v.Character.HumanoidRootPart.Position - HRP.Position).Magnitude
					if d < Dist then Dist = d; Target = v.Character.HumanoidRootPart end
				end
			end
		end
		
		-- Check Mobs (Overrides Players if closer/enabled)
		if State.AimMobs then
			local Mobs = workspace:FindFirstChild("Enemies") or workspace:FindFirstChild("Mobs") or workspace
			for _, v in pairs(Mobs:GetChildren()) do
				if v:FindFirstChild("Humanoid") and v:FindFirstChild("HumanoidRootPart") and v.Humanoid.Health > 0 then
					local d = (v.HumanoidRootPart.Position - HRP.Position).Magnitude
					if d < Dist then Dist = d; Target = v.HumanoidRootPart end
				end
			end
		end
		
		if Target then Camera.CFrame = CFrame.new(Camera.CFrame.Position, Target.Position) end
	end
end)

