-- 5. UI ANIMATION LOGIC
local function ToggleUI(state)
	if state == "Open" then
		MiniFrame.Visible = false
		MainFrame.Visible = true
		
		-- Pop-in Effect
		MainFrame.Size = UDim2.new(0, 240, 0, 200)
		local tween = TweenService:Create(MainFrame, TweenInfo.new(0.3, Enum.EasingStyle.Back), {Size = UDim2.new(0, 260, 0, 220)})
		tween:Play()
	else
		MainFrame.Visible = false
		MiniFrame.Visible = true
	end
end

