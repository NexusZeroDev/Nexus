		-- Simple example for Sea 1 quests, expand logic as needed
		if MyLevel >= 1 and MyLevel <= 9 then -- Bandit Quest
			if not LocalPlayer.PlayerGui.Main.Quest.Visible or LocalPlayer.PlayerGui.Main.Quest.Container.QuestTitle.TitleLabel.Text ~= "Bandit [Lv. 5]" then
				Tween(CFrame.new(1060.9383544922, 16.455066680908, 1547.7841796875)) -- Quest NPC Position
				wait(1)
				CommF:InvokeServer("StartQuest", "BanditQuest1", 1)
			elseif LocalPlayer.PlayerGui.Main.Quest.Visible and LocalPlayer.PlayerGui.Main.Quest.Container.QuestTitle.TitleLabel.Text == "Bandit [Lv. 5]" then
				local Mob = GetNearestEnemy()
				if Mob then
					StatusLabel.Text = "AutoQuest: Attacking "..Mob.Name
					Tween(Mob.HumanoidRootPart.CFrame * CFrame.new(0, 30, 0))
					Attack()
				else
					StatusLabel.Text = "AutoQuest: Finding Bandit..."
				end
			end
		elseif MyLevel >= 10 and MyLevel <= 14 then -- Monkey Quest
			if not LocalPlayer.PlayerGui.Main.Quest.Visible or LocalPlayer.PlayerGui.Main.Quest.Container.QuestTitle.TitleLabel.Text ~= "Monkey [Lv. 14]" then
				Tween(CFrame.new(-1601.6553955078, 36.85213470459, -102.27299499512)) -- Quest NPC Position
				wait(1)
				CommF:InvokeServer("StartQuest", "JungleQuest", 1)
			elseif LocalPlayer.PlayerGui.Main.Quest.Visible and LocalPlayer.PlayerGui.Main.Quest.Container.QuestTitle.TitleLabel.Text == "Monkey [Lv. 14]" then
				local Mob = GetNearestEnemy()
				if Mob then
					StatusLabel.Text = "AutoQuest: Attacking "..Mob.Name
					Tween(Mob.HumanoidRootPart.CFrame * CFrame.new(0, 30, 0))
					Attack()
				else
					StatusLabel.Text = "AutoQuest: Finding Monkey..."
				end
			end
		-- Add more quest levels here following the same pattern...
		else
			StatusLabel.Text = "AutoQuest: Reached High Level, Check Quest."
		end
	end

	-- [[ OBSERVATION HAKI FARM ]]
	if Settings.ObservationFarm then
		local Tool = Char:FindFirstChildOfClass("Tool") or LocalPlayer.Backpack:FindFirstChildOfClass("Tool")
		if Tool and Tool.Parent == LocalPlayer.Backpack then Tool.Parent = Char end

		local Enemy = GetNearestObsFarmEnemy() -- Use the new function
		if Enemy then
			StatusLabel.Text = "Obs Farm: Attacking: " .. Enemy.Name
			local EnemyPos = Enemy.HumanoidRootPart.Position
			-- Look at enemy
			local LookCFrame = CFrame.new(EnemyPos + Vector3.new(0, Settings.FarmDistance, 0), EnemyPos)
			
			HRP.CFrame = HRP.CFrame:Lerp(LookCFrame, Settings.Smoothness)
			HRP.Velocity = Vector3.new(0,0,0) -- Freeze physics
			
			Attack()
		else
			StatusLabel.Text = "Obs Farm: Searching for Targets..."
		end
	end

	-- [[ AUTO FARM ]]
	if Settings.AutoFarm and not Settings.ObservationFarm then -- Ensure it doesn't run alongside Obs Farm
		local Tool = Char:FindFirstChildOfClass("Tool") or LocalPlayer.Backpack:FindFirstChildOfClass("Tool")
		if Tool and Tool.Parent == LocalPlayer.Backpack then Tool.Parent = Char end

		local Enemy = GetNearestEnemy()
		if Enemy then
			StatusLabel.Text = "Attacking: " .. Enemy.Name
			local EnemyPos = Enemy.HumanoidRootPart.Position
			-- Look at enemy
			local LookCFrame = CFrame.new(EnemyPos + Vector3.new(0, Settings.FarmDistance, 0), EnemyPos)
			
			HRP.CFrame = HRP.CFrame:Lerp(LookCFrame, Settings.Smoothness)
			HRP.Velocity = Vector3.new(0,0,0) -- Freeze physics
			
			Attack()
		else
			StatusLabel.Text = "Status: Searching for Mobs..."
		end
	end

	-- [[ CHEST FARM ]]
	if Settings.ChestFarm then
		local Chest = GetNearestChest()
		if Chest then
			StatusLabel.Text = "Collecting: " .. Chest.Name
			local ChestPos = Chest:IsA("Model") and Chest.PrimaryPart.Position or Chest.Position
			local Dist = (HRP.Position - ChestPos).Magnitude
			
			if Dist < 6 then
				-- We are close enough
				Char.Humanoid.Jump = true
				table.insert(Settings.IgnoredChests, Chest) -- Don't target this again immediately
				StatusLabel.Text = "Collected! Moving to next..."
				
				-- Clean ignore list occasionally
				task.delay(15, function()
					for i,v in pairs(Settings.IgnoredChests) do
						if v == Chest then table.remove(Settings.IgnoredChests, i) end
					end
				end)
			else
				HRP.CFrame = HRP.CFrame:Lerp(CFrame.new(ChestPos), Settings.Smoothness)
				HRP.Velocity = Vector3.new(0,0,0)
			end
		else
			StatusLabel.Text = "Status: No Chests Found"
		end
	end

	-- NEW: ESP Update Loop
	if Settings.ESPEnabled then
		UpdateESP()
	else
		ClearESP()
	end
end)

-- 7. BUTTON LOGIC
local function ToggleFlight(enable)
	local Char = LocalPlayer.Character
	if not Char or not Char:FindFirstChild("HumanoidRootPart") then return end
	
	if enable then
		local BV = Instance.new("BodyVelocity")
		BV.Name = "FlyVelocity"
		BV.Parent = Char.HumanoidRootPart
		BV.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
		BV.Velocity = Vector3.new(0,0,0)
	else
		if Char.HumanoidRootPart:FindFirstChild("FlyVelocity") then
			Char.HumanoidRootPart.FlyVelocity:Destroy()
		end
	end
end

