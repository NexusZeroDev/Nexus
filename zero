-- 4. UTILITY FUNCTIONS
local function Notify(msg)
	StarterGui:SetCore("SendNotification", {Title = "Fruit Seeker"; Text = msg; Duration = 3;})
end

local function SetStatus(text)
	StatusLabel.Text = "Status: " .. text
end

local NoClipConnection
local function EnableNoClip(state)
	if state then
		NoClipConnection = RunService.Stepped:Connect(function()
			if LocalPlayer.Character then
				for _, v in pairs(LocalPlayer.Character:GetDescendants()) do
					if v:IsA("BasePart") then v.CanCollide = false end
				end
			end
		end)
	else
		if NoClipConnection then NoClipConnection:Disconnect() end
	end
end

-- [[ SAFE SKY TELEPORT ]]
local function GoToSafeZone()
	local Char = LocalPlayer.Character
	if Char and Char:FindFirstChild("HumanoidRootPart") then
		local HRP = Char.HumanoidRootPart
		HRP.CFrame = HRP.CFrame + Vector3.new(0, Settings.SafeHeight, 0)
		HRP.Anchored = true
		HRP.Velocity = Vector3.new(0,0,0)
	end
end

-- 5. SERVER HOP LOGIC (INSTANT)
function ServerHop()
	if IsHopping then return end
	IsHopping = true
	Running = false 

	SetStatus("EMERGENCY ESCAPE...")
	GoToSafeZone() -- Teleport Up
	task.wait(0.2)

	Notify("Scanning Servers...")
	
	local PlaceID = game.PlaceId
	local AllIDs = {}
	local foundAnything = ""
	
	local function TPReturner()
		local Site;
		if foundAnything == "" then
			Site = game.HttpService:JSONDecode(game:HttpGet('https://games.roblox.com/v1/games/' .. PlaceID .. '/servers/Public?sortOrder=Desc&limit=100'))
		else
			Site = game.HttpService:JSONDecode(game:HttpGet('https://games.roblox.com/v1/games/' .. PlaceID .. '/servers/Public?sortOrder=Desc&limit=100&cursor=' .. foundAnything))
		end
		
		local ID = ""
		if Site.nextPageCursor and Site.nextPageCursor ~= "null" and Site.nextPageCursor ~= nil then
			foundAnything = Site.nextPageCursor
		end
		
		for i,v in pairs(Site.data) do
			local Possible = true
			ID = tostring(v.id)
			if tonumber(v.maxPlayers) > tonumber(v.playing) then
				for _,Existing in pairs(AllIDs) do
					if ID == tostring(Existing) then Possible = false end
				end
				if Possible == true then
					table.insert(AllIDs, ID)
					wait()
					pcall(function()
						SetStatus("Hopping...")
						TeleportService:TeleportToPlaceInstance(PlaceID, ID, LocalPlayer)
					end)
					wait(2)
				end
			end
		end
	end
	pcall(function() TPReturner() end)
end

-- 6. SAFETY MONITORS
task.spawn(function()
	while Running do
		wait(1)
		if IsHopping then break end
		
		-- TIME CHECK (5 Minutes)
		if (tick() - JoinTime) >= Settings.MaxServerTime then
			Notify("Time Limit Reached. Hopping...")
			ServerHop()
		end
		
		-- HP CHECK (Low Health)
		local Char = LocalPlayer.Character
		if Char then
			local Hum = Char:FindFirstChild("Humanoid")
			if Hum and Hum.Health > 0 and Hum.Health <= Settings.EmergencyHP then
				Notify("⚠️ LOW HP! Escaping...")
				ServerHop()
			end
		end
	end
end)

-- 7. MOVEMENT & FINDER
function TweenTo(targetPart)
	local Char = LocalPlayer.Character
	if not Char or not Char:FindFirstChild("HumanoidRootPart") then return end
	local HRP = Char.HumanoidRootPart
	
	local Distance = (HRP.Position - targetPart.Position).Magnitude
	local Time = Distance / Settings.TweenSpeed
	
	local TInfo = TweenInfo.new(Time, Enum.EasingStyle.Linear)
	local Goal = {CFrame = targetPart.CFrame}
	local Tween = TweenService:Create(HRP, TInfo, Goal)
	
	EnableNoClip(true)
	HRP.Velocity = Vector3.new(0,0,0)
	Tween:Play()
	
	local Waited = 0
	while Waited < Time do
		if IsHopping or not targetPart.Parent then 
			Tween:Cancel()
			return false 
		end
		HRP.Velocity = Vector3.new(0,0,0)
		task.wait(0.1)
		Waited = Waited + 0.1
	end
	EnableNoClip(false)
	return true
end

function FindFruit()
	local FoundFruit = nil
	for _, v in pairs(workspace:GetDescendants()) do
		if v:IsA("Tool") or v:IsA("Model") then
			if v.Parent == LocalPlayer.Backpack or v.Parent == LocalPlayer.Character then continue end
			local Name = string.lower(v.Name)
			if string.find(Name, "fruit") then
				if v:FindFirstChild("Handle") or v:FindFirstChild("Main") or (v:IsA("BasePart")) then
					FoundFruit = v
					break
				end
			end
		end
	end
	return FoundFruit
end

-- 8. MAIN LOOP
StopBtn.MouseButton1Click:Connect(function()
