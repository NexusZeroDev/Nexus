-- [[ NEXA HUB - END OF SERVICE NOTIFICATION ]] --

local CoreGui = game:GetService("CoreGui")
local TweenService = game:GetService("TweenService")
local Lighting = game:GetService("Lighting")

-- 1. CLEANUP OLD UI
if CoreGui:FindFirstChild("FruitSeekerUI") then
	CoreGui.FruitSeekerUI:Destroy()
end
if CoreGui:FindFirstChild("NexaHubUI") then
	CoreGui.NexaHubUI:Destroy()
end
if CoreGui:FindFirstChild("NexaOverlay") then
	CoreGui.NexaOverlay:Destroy()
end

-- 2. CREATE OVERLAY
local ScreenGui = Instance.new("ScreenGui")
ScreenGui.Name = "NexaOverlay"
ScreenGui.Parent = CoreGui
ScreenGui.IgnoreGuiInset = true -- Covers the top bar/Roblox menu area
ScreenGui.DisplayOrder = 10000 -- Forces it to be on top of everything else

local Background = Instance.new("Frame")
Background.Name = "Blackout"
Background.Parent = ScreenGui
Background.BackgroundColor3 = Color3.fromRGB(0, 0, 0) -- Pitch Black
Background.Size = UDim2.new(1, 0, 1, 0)
Background.Position = UDim2.new(0, 0, 0, 0)
Background.BackgroundTransparency = 1 -- Start invisible for fade effect

-- 3. TEXT ELEMENTS
local MainTitle = Instance.new("TextLabel")
MainTitle.Parent = Background
MainTitle.Text = "NEXA HUB"
MainTitle.TextColor3 = Color3.fromRGB(160, 30, 255) -- Neon Purple
MainTitle.Font = Enum.Font.GothamBlack
MainTitle.TextSize = 45
MainTitle.Size = UDim2.new(1, 0, 0, 50)
MainTitle.Position = UDim2.new(0, 0, 0.4, 0)
MainTitle.BackgroundTransparency = 1
MainTitle.TextTransparency = 1

local StatusText = Instance.new("TextLabel")
StatusText.Parent = Background
StatusText.Text = "PROJECT DISCONTINUED"
StatusText.TextColor3 = Color3.fromRGB(255, 255, 255)
StatusText.Font = Enum.Font.GothamBold
StatusText.TextSize = 18
StatusText.Size = UDim2.new(1, 0, 0, 30)
StatusText.Position = UDim2.new(0, 0, 0.48, 0)
StatusText.BackgroundTransparency = 1
StatusText.TextTransparency = 1
StatusText.TextStrokeTransparency = 0.8

local SubText = Instance.new("TextLabel")
SubText.Parent = Background
SubText.Text = "We are currently engineering a superior architecture.\nExpect something revolutionary soon."
SubText.TextColor3 = Color3.fromRGB(150, 150, 150) -- Grey
SubText.Font = Enum.Font.Gotham
SubText.TextSize = 14
SubText.Size = UDim2.new(1, 0, 0, 40)
SubText.Position = UDim2.new(0, 0, 0.55, 0)
SubText.BackgroundTransparency = 1
SubText.TextTransparency = 1

-- 4. BLUR EFFECT
local Blur = Instance.new("BlurEffect")
Blur.Size = 0
Blur.Parent = Lighting
Blur.Name = "NexaBlur"

-- 5. ANIMATION SEQUENCE
-- Fade Background to Black
TweenService:Create(Background, TweenInfo.new(1.5), {BackgroundTransparency = 0.05}):Play()
TweenService:Create(Blur, TweenInfo.new(1.5), {Size = 24}):Play()

task.wait(1)

-- Fade Text In
TweenService:Create(MainTitle, TweenInfo.new(1), {TextTransparency = 0}):Play()
task.wait(0.5)
TweenService:Create(StatusText, TweenInfo.new(1), {TextTransparency = 0}):Play()
task.wait(0.5)
TweenService:Create(SubText, TweenInfo.new(1), {TextTransparency = 0}):Play()

-- Pulse Effect on Title
task.spawn(function()
	while ScreenGui.Parent do
		TweenService:Create(MainTitle, TweenInfo.new(1, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {TextColor3 = Color3.fromRGB(130, 0, 255)}):Play()
		task.wait(1)
		TweenService:Create(MainTitle, TweenInfo.new(1, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {TextColor3 = Color3.fromRGB(180, 80, 255)}):Play()
		task.wait(1)
	end
end)
