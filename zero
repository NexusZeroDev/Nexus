-- 5. LOGIC LOOPS (RUNTIME)
RunService.RenderStepped:Connect(function()
	local Char = LocalPlayer.Character
	if not Char then return end
	local Hum = Char:FindFirstChild("Humanoid")
	local HRP = Char:FindFirstChild("HumanoidRootPart")
	
	-- SPEED & JUMP
	if Hum and State.SpeedEnabled then
		Hum.WalkSpeed = State.SpeedAmt
	end
	if Hum then
		Hum.JumpPower = State.JumpAmt
	end
	
	-- WALK ON WATER
	if HRP and State.WalkWater then
		local Platform = workspace:FindFirstChild("NexaWaterPlat")
		if not Platform then
			Platform = Instance.new("Part")
			Platform.Name = "NexaWaterPlat"
			Platform.Parent = workspace
			Platform.Anchored = true
			Platform.Transparency = 1
			Platform.Size = Vector3.new(20, 1, 20)
			Platform.CanCollide = true
		end
		-- Keep under feet, level at Y=-2 (Water level approx)
		Platform.CFrame = CFrame.new(HRP.Position.X, -2, HRP.Position.Z)
	else
		if workspace:FindFirstChild("NexaWaterPlat") then workspace.NexaWaterPlat:Destroy() end
	end
	
	-- ANTI STUN
	if Hum and State.AntiStun then
		Hum.PlatformStand = false
		Hum.Sit = false
		if Hum:GetState() == Enum.HumanoidStateType.Physics then
			Hum:ChangeState(Enum.HumanoidStateType.Running)
		end
	end
	
	-- SAFE MODE
	if Hum and State.SafeMode then
		if Hum.Health < State.SafeHP and Hum.Health > 0 then
			if HRP then
				HRP.CFrame = HRP.CFrame + Vector3.new(0, 500, 0)
				HRP.Anchored = true
			end
		end
	end
	
	-- AIM LOCK / AIM NEAR
	if State.AimLock and HRP then
		local Closest = nil
		local ShortestDist = 9999
		local SearchFolder = (State.AimTarget == "Mobs") and (workspace:FindFirstChild("Enemies") or workspace:FindFirstChild("Mobs") or workspace) or Players
		
		if State.AimTarget == "Mobs" then
			for _,v in pairs(SearchFolder:GetChildren()) do
				if v:FindFirstChild("HumanoidRootPart") and v:FindFirstChild("Humanoid") and v.Humanoid.Health > 0 then
					local dist = (v.HumanoidRootPart.Position - HRP.Position).Magnitude
					if dist < ShortestDist then ShortestDist = dist; Closest = v.HumanoidRootPart end
				end
			end
		else
			for _,v in pairs(Players:GetPlayers()) do
				if v ~= LocalPlayer and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
					local dist = (v.Character.HumanoidRootPart.Position - HRP.Position).Magnitude
					if dist < ShortestDist then ShortestDist = dist; Closest = v.Character.HumanoidRootPart end
				end
			end
		end
		
		if Closest then
			Camera.CFrame = CFrame.new(Camera.CFrame.Position, Closest.Position)
		end
	end
end)

-- ESP Function
local function UpdateESP()
	for _,v in pairs(workspace:GetDescendants()) do
		if v:IsA("Highlight") and v.Name == "NexaESP" then v:Destroy() end
	end
	
	if not State.ESP then return end
	
	local function Highlight(model, color)
		local h = Instance.new("Highlight")
		h.Name = "NexaESP"
		h.Parent = model
		h.FillColor = color
		h.OutlineColor = Color3.new(1,1,1)
		h.FillTransparency = 0.5
	end
	
	-- ESP Logic (Simple refresh)
	for _, p in pairs(Players:GetPlayers()) do
		if p ~= LocalPlayer and p.Character then Highlight(p.Character, Color3.fromRGB(255, 0, 0)) end
	end
	
	local MobFolder = workspace:FindFirstChild("Enemies") or workspace:FindFirstChild("Mobs")
	if MobFolder then
		for _, m in pairs(MobFolder:GetChildren()) do
			if m:FindFirstChild("Humanoid") then Highlight(m, Color3.fromRGB(255, 170, 0)) end
		end
	end
end

-- 6. TAB SYSTEM
local function LoadTab(name)
	ClearContent()
	AddList()
	
	if name == "Main" then
		AddToggle("Speed Boost (Enable Multiplier)", State.SpeedEnabled, function(v) State.SpeedEnabled = v end)
		AddInput("Speed Amount", State.SpeedAmt, function(v) State.SpeedAmt = v end)
		AddInput("Jump Power", State.JumpAmt, function(v) State.JumpAmt = v end)
		AddToggle("Walk on Water", State.WalkWater, function(v) State.WalkWater = v end)
		AddToggle("Anti-Stun", State.AntiStun, function(v) State.AntiStun = v end)
		AddToggle("High Performance (Low Gfx)", State.HighPerf, function(v)
			State.HighPerf = v
			if v then
				setfpscap(30)
				Lighting.GlobalShadows = false
			else
				setfpscap(999)
				Lighting.GlobalShadows = true
			end
		end)
	
	elseif name == "Combat" then
		AddToggle("Aim Lock", State.AimLock, function(v) State.AimLock = v end)
		AddToggle("Aim Target: Players (Off = Mobs)", true, function(v) State.AimTarget = v and "Players" or "Mobs" end)
		AddToggle("ESP (Players & Mobs)", State.ESP, function(v) 
			State.ESP = v 
			task.spawn(function()
				while State.ESP do UpdateESP(); task.wait(3) end -- Update ESP every 3s
				UpdateESP() -- Clear
			end)
		end)
		
	elseif name == "Safety" then
		AddToggle("Enable Safe Mode (Auto TP)", State.SafeMode, function(v) State.SafeMode = v end)
		AddInput("HP Threshold", State.SafeHP, function(v) State.SafeHP = v end)
	end
end

local function CreateTabBtn(name)
