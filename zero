local function RemoveESP()
	for _, v in pairs(workspace:GetDescendants()) do
		if v.Name == "NexaESP" or v.Name == "NexaInfo" then v:Destroy() end
	end
end

local function DrawESP(char, player)
	if not char or not char:FindFirstChild("HumanoidRootPart") then return end
	if char:FindFirstChild("NexaESP") then return end -- Already has ESP

	-- 1. Determine Team/Faction Color
	local TeamColor = Color3.fromRGB(255, 255, 255) -- Default White
	local FactionText = "Player"

	if player.Team then
		local tName = string.lower(player.Team.Name)
		if string.find(tName, "pirate") then
			TeamColor = Color3.fromRGB(255, 60, 60) -- RED for Pirates
			FactionText = "Pirate"
		elseif string.find(tName, "marine") then
			TeamColor = Color3.fromRGB(60, 150, 255) -- BLUE for Marines
			FactionText = "Marine"
		end
	end

	-- 2. Create Highlight (Chams)
	local HL = Instance.new("Highlight")
	HL.Name = "NexaESP"
	HL.Parent = char
	HL.FillColor = TeamColor
	HL.OutlineColor = Color3.new(1,1,1)
	HL.FillTransparency = 0.6
	HL.OutlineTransparency = 0.2

	-- 3. Create Text Info (Billboard)
	local BG = Instance.new("BillboardGui")
	BG.Name = "NexaInfo"
	BG.Parent = char.HumanoidRootPart
	BG.Size = UDim2.new(0, 200, 0, 50)
	BG.StudsOffset = Vector3.new(0, 3.5, 0) -- Above Head
	BG.AlwaysOnTop = true

	local InfoLabel = Instance.new("TextLabel")
	InfoLabel.Parent = BG
	InfoLabel.Size = UDim2.new(1, 0, 1, 0)
	InfoLabel.BackgroundTransparency = 1
	InfoLabel.Font = Enum.Font.GothamBold
	InfoLabel.TextStrokeTransparency = 0
	InfoLabel.TextColor3 = TeamColor
	InfoLabel.TextSize = 12
	InfoLabel.Text = "Loading..." -- Placeholder
	
	-- Store references for the Update loop
	BG:SetAttribute("Faction", FactionText)
end

-- ===========================
--     RUNTIME LOOPS
-- ===========================

RunService.RenderStepped:Connect(function()
	local Char = LocalPlayer.Character
	if not Char then return end
	local Hum = Char:FindFirstChild("Humanoid")
	local HRP = Char:FindFirstChild("HumanoidRootPart")
	
	-- LOGIC: SPEED, JUMP, WATER, STUN
	if Hum and State.SpeedEnabled then Hum.WalkSpeed = State.SpeedAmt end
	if Hum then Hum.JumpPower = State.JumpAmt end
	
	if HRP and State.WalkWater then
		local Platform = workspace:FindFirstChild("NexaWaterPlat")
		if not Platform then
			Platform = Instance.new("Part"); Platform.Name = "NexaWaterPlat"; Platform.Parent = workspace; Platform.Anchored = true; Platform.Transparency = 1; Platform.Size = Vector3.new(20, 1, 20); Platform.CanCollide = true
		end
		Platform.CFrame = CFrame.new(HRP.Position.X, -2, HRP.Position.Z)
	else
		if workspace:FindFirstChild("NexaWaterPlat") then workspace.NexaWaterPlat:Destroy() end
	end
	
	if Hum and State.AntiStun then
		Hum.PlatformStand = false; Hum.Sit = false
		if Hum:GetState() == Enum.HumanoidStateType.Physics then Hum:ChangeState(Enum.HumanoidStateType.Running) end
	end
	
	if Hum and State.SafeMode and Hum.Health < State.SafeHP and Hum.Health > 0 and HRP then
		HRP.CFrame = HRP.CFrame + Vector3.new(0, 500, 0); HRP.Anchored = true
	end

	-- LOGIC: ESP UPDATER
	if State.ESP then
		for _, p in pairs(Players:GetPlayers()) do
			if p ~= LocalPlayer and p.Character then
				-- Add ESP if missing
				if not p.Character:FindFirstChild("NexaESP") then
					DrawESP(p.Character, p)
				end
				
				-- Update Text
				local InfoGUI = p.Character:FindFirstChild("HumanoidRootPart") and p.Character.HumanoidRootPart:FindFirstChild("NexaInfo")
				local pHum = p.Character:FindFirstChild("Humanoid")
				
				if InfoGUI and InfoGUI:FindFirstChild("TextLabel") and HRP and pHum then
					local Dist = math.floor((HRP.Position - p.Character.HumanoidRootPart.Position).Magnitude)
					local HP = math.floor((pHum.Health / pHum.MaxHealth) * 100)
					local Fac = InfoGUI:GetAttribute("Faction") or "Player"
					
					InfoGUI.TextLabel.Text = string.format("[%s] %s\nHP: %d%% | Dist: %dm", Fac, p.Name, HP, Dist)
				end
			end
		end
	else
		RemoveESP()
	end
end)

-- 6. TAB SYSTEM
local function LoadTab(name)
	ClearContent()
	AddList()
	
	if name == "Main" then
		AddToggle("Speed Boost (Enable Multiplier)", State.SpeedEnabled, function(v) State.SpeedEnabled = v end)
		AddInput("Speed Amount", State.SpeedAmt, function(v) State.SpeedAmt = v end)
		AddInput("Jump Power", State.JumpAmt, function(v) State.JumpAmt = v end)
		AddToggle("Walk on Water", State.WalkWater, function(v) State.WalkWater = v end)
		AddToggle("Anti-Stun", State.AntiStun, function(v) State.AntiStun = v end)
		AddToggle("High Performance (Low Gfx)", State.HighPerf, function(v)
			State.HighPerf = v
			if v then setfpscap(30); Lighting.GlobalShadows = false
			else setfpscap(999); Lighting.GlobalShadows = true end
		end)
	
	elseif name == "Combat" then
		AddToggle("Aim Lock", State.AimLock, function(v) State.AimLock = v end)
		AddToggle("Aim Target: Players (Off = Mobs)", true, function(v) State.AimTarget = v and "Players" or "Mobs" end)
		AddToggle("Advanced ESP (HP/Dist/Team)", State.ESP, function(v) 
			State.ESP = v 
			if not v then RemoveESP() end
		end)
		
	elseif name == "Safety" then
		AddToggle("Enable Safe Mode (Auto TP)", State.SafeMode, function(v) State.SafeMode = v end)
		AddInput("HP Threshold", State.SafeHP, function(v) State.SafeHP = v end)
	end
end

local function CreateTabBtn(name)
	local Btn = Instance.new("TextButton"); Btn.Parent = TabHolder; Btn.Size = UDim2.new(1, -10, 0, 35); Btn.BackgroundTransparency = 1
	Btn.Text = "  " .. name; Btn.TextColor3 = Settings.Dim; Btn.TextXAlignment = Enum.TextXAlignment.Left; Btn.Font = Enum.Font.GothamMedium; Btn.TextSize = 14
	Btn.MouseButton1Click:Connect(function() LoadTab(name) end)
end

