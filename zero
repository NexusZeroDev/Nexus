-- LOOP: Auto Farm Logic
RunService.RenderStepped:Connect(function()
	if Settings.AutoFarm then
		local Character = LocalPlayer.Character
		if not Character or not Character:FindFirstChild("HumanoidRootPart") then return end
		
		-- 1. Equip a Weapon (First Tool found)
		local Tool = Character:FindFirstChildOfClass("Tool")
		if not Tool then
			local BackpackTool = LocalPlayer.Backpack:FindFirstChildOfClass("Tool")
			if BackpackTool then BackpackTool.Parent = Character end
		end

		-- 2. Find Enemy
		local Enemy = GetNearestEnemy()
		if Enemy then
			StatusLabel.Text = "Attacking: " .. Enemy.Name
			
			-- 3. Calculate Position (Above the enemy)
			local TargetPos = Enemy.HumanoidRootPart.CFrame * CFrame.new(0, Settings.FarmDistance, 0)
			
			-- 4. Move there
			MoveTo(TargetPos)
			
			-- 5. Look down at enemy
			Character.HumanoidRootPart.CFrame = CFrame.new(Character.HumanoidRootPart.Position, Enemy.HumanoidRootPart.Position)
			
			-- 6. Attack
			-- Try standard activation
			if Tool then Tool:Activate() end
			-- Try Virtual Click (Backup)
			Click()
			
			-- Float Logic (Prevent falling)
			if not Character.HumanoidRootPart:FindFirstChild("BodyVelocity") then
				local BV = Instance.new("BodyVelocity")
				BV.Parent = Character.HumanoidRootPart
				BV.Velocity = Vector3.new(0, 0, 0)
				BV.MaxForce = Vector3.new(Math.huge, Math.huge, Math.huge)
			end
		else
			StatusLabel.Text = "Status: Searching for mobs..."
			-- Remove Float if no enemy
			if Character.HumanoidRootPart:FindFirstChild("BodyVelocity") then
				Character.HumanoidRootPart.BodyVelocity:Destroy()
			end
		end
	else
		-- Remove Float if turned off
		if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") and LocalPlayer.Character.HumanoidRootPart:FindFirstChild("BodyVelocity") then
			LocalPlayer.Character.HumanoidRootPart.BodyVelocity:Destroy()
		end
	end
end)

