-- 7. TARGET FINDER
function GetTarget()
	local ClosestDist = 500
	local Target = nil
	local Folder = workspace:FindFirstChild("Enemies") or workspace:FindFirstChild("Mobs") or workspace
	
	for _, v in pairs(Folder:GetChildren()) do
		if v:FindFirstChild("Humanoid") and v:FindFirstChild("HumanoidRootPart") and v.Humanoid.Health > 0 then
			local Char = LocalPlayer.Character
			if Char and Char:FindFirstChild("HumanoidRootPart") then
				local Dist = (Char.HumanoidRootPart.Position - v.HumanoidRootPart.Position).Magnitude
				if Dist < ClosestDist then
					ClosestDist = Dist
					Target = v
				end
			end
		end
	end
	return Target
end

-- 8. MAIN LOOPS

-- Attack Loop (Runs separately)
task.spawn(function()
	while true do
		if Settings.AutoFarm then
			pcall(function() AutoClick() end)
		end
		task.wait(0.1) -- Click speed
	end
end)

-- Movement Loop (Runs every frame)
RunService.RenderStepped:Connect(function()
	if Settings.AutoFarm then
		local Char = LocalPlayer.Character
		if not Char or not Char:FindFirstChild("HumanoidRootPart") then return end
		local HRP = Char.HumanoidRootPart
		
		-- Equip Tool
		local Tool = Char:FindFirstChildOfClass("Tool")
		if not Tool then
			local BackpackTool = LocalPlayer.Backpack:FindFirstChildOfClass("Tool")
			if BackpackTool then BackpackTool.Parent = Char end
		end

		local Enemy = GetTarget()
		if Enemy then
			StatusLabel.Text = "Attack: " .. Enemy.Name
			local EnemyHRP = Enemy.HumanoidRootPart
			
			-- [[ THE FIX: POSITION BEHIND ENEMY ]] --
			-- We use CFrame * CFrame.new(0,0,distance) to go behind
			-- 0,0,4 means 4 studs backwards from where the enemy is facing
			local BehindPos = EnemyHRP.CFrame * CFrame.new(0, 0, Settings.Distance)
			
			-- Tween or Set CFrame
			HRP.CFrame = BehindPos
			
			-- FORCE FACE THE ENEMY (Crucial for hits to register)
			HRP.CFrame = CFrame.new(HRP.Position, EnemyHRP.Position)
			
			-- NoClip & No Physics
			HRP.Velocity = Vector3.new(0,0,0)
			for _, part in pairs(Char:GetDescendants()) do
				if part:IsA("BasePart") then part.CanCollide = false end
			end
		else
			StatusLabel.Text = "Scanning..."
		end
	end
end)
