-- SEPARATE ATTACK LOOP (Prevents Lag)
task.spawn(function()
	while true do
		if Settings.AutoFarm then
			-- Only click if we have a target and we are close
			local Enemy = GetNearestEnemy()
			if Enemy then
				local Char = LocalPlayer.Character
				if Char and Char:FindFirstChild("HumanoidRootPart") then
					local Dist = (Char.HumanoidRootPart.Position - Enemy.HumanoidRootPart.Position).Magnitude
					if Dist < 15 then -- Only click if close
						AutoClick()
					end
				end
			end
		end
		-- Adjust Speed here (0.1 is fast, 0.5 is slow)
		task.wait(0.2) 
	end
end)

-- MOVEMENT LOOP
RunService.RenderStepped:Connect(function()
	if Settings.AutoFarm then
		local Char = LocalPlayer.Character
		if not Char or not Char:FindFirstChild("HumanoidRootPart") then return end
		local HRP = Char.HumanoidRootPart

		-- Auto Equip Tool if not held
		local Tool = Char:FindFirstChildOfClass("Tool")
		if not Tool then
			local BackpackTool = LocalPlayer.Backpack:FindFirstChildOfClass("Tool")
			if BackpackTool then BackpackTool.Parent = Char end
		end

		local Enemy = GetNearestEnemy()
		if Enemy then
			StatusLabel.Text = "Killing: " .. Enemy.Name
			local EnemyPos = Enemy.HumanoidRootPart.Position
			-- Teleport Behind Enemy
			local TargetCFrame = CFrame.new(EnemyPos + Vector3.new(0, 0, Settings.FarmDistance), EnemyPos)
			
			HRP.CFrame = HRP.CFrame:Lerp(TargetCFrame, Settings.Smoothness)
			HRP.Velocity = Vector3.new(0,0,0) -- Stop Falling
		else
			StatusLabel.Text = "Scanning..."
		end
	end
end)
