-- 7. SLIDE DOWN INTRO
function PlayIntro()
	-- Wait a moment for game to load
	task.wait(1)
	
	-- Sound Effect (Optional, subtle pop)
	local sound = Instance.new("Sound")
	sound.Parent = TopBar
	sound.SoundId = "rbxassetid://6895079853" -- UI Open Sound
	sound.Volume = 0.5
	sound.PlayOnRemove = true
	sound:Destroy()

	-- The Slide Animation
	-- EasingStyle.Exponential makes it start fast and slow down smoothly
	local SlideInfo = TweenInfo.new(1.2, Enum.EasingStyle.Exponential, Enum.EasingDirection.Out)
	
	-- Target Position: Top Center (Y = 15 pixels padding from top)
	local TargetPos = UDim2.new(0.5, -(Settings.BarWidth/2), 0, 15)
	
	local Tween = TweenService:Create(TopBar, SlideInfo, {Position = TargetPos})
	Tween:Play()
end

PlayIntro()
