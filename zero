-- Optimized Finder
function GetNearestEnemy()
	local ClosestDist = 1000
	local Target = nil
	-- Optimizing: Assuming "Enemies" folder exists. 
	local Folder = workspace:FindFirstChild("Enemies") or workspace
	
	for _, v in pairs(Folder:GetChildren()) do
		if v:FindFirstChild("Humanoid") and v:FindFirstChild("HumanoidRootPart") and v.Humanoid.Health > 0 then
			local MyPos = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
			if MyPos then
				local Dist = (MyPos.Position - v.HumanoidRootPart.Position).Magnitude
				if Dist < ClosestDist then
					ClosestDist = Dist
					Target = v
				end
			end
		end
	end
	return Target
end

function GetNearestChest()
	local ClosestDist = 99999
	local Target = nil
	local MyPos = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
	
	if not MyPos then return nil end

	-- Optimizing: Only check folders or common locations if possible, but we'll use Descendants safely
	for _, v in pairs(workspace:GetDescendants()) do
		if (v.Name:find("Chest") or v.Name:find("Crate")) and (v:IsA("Part") or v:IsA("Model")) then
			if table.find(Settings.IgnoredChests, v) then continue end
			if v:IsA("Model") and not v.PrimaryPart then continue end
			
			local Pos = v:IsA("Model") and v.PrimaryPart.Position or v.Position
			local Dist = (MyPos.Position - Pos).Magnitude
			
			if Dist < ClosestDist then
				ClosestDist = Dist
				Target = v
			end
		end
	end
	return Target
end

