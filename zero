local function LoadTab(name)
	ClearContent()
	local L = Instance.new("UIListLayout"); L.Parent=Content; L.Padding=UDim.new(0,5); L.SortOrder=Enum.SortOrder.LayoutOrder

	if name == "Main" then
		AddToggle("Speed Boost", State.SpeedEnabled, function(v) State.SpeedEnabled = v end)
		AddInput("Speed Amount", State.SpeedAmt, function(v) State.SpeedAmt = v end)
		AddToggle("Jump Boost", State.JumpEnabled, function(v) State.JumpEnabled = v end)
		AddToggle("Spawn Jump Ball", State.JumpBall, function(v) State.JumpBall = v; UpdateJumpBall() end)
		AddToggle("Walk on Water", State.WalkWater, function(v) State.WalkWater = v end)
		
	elseif name == "Combat" then
		AddToggle("Aim: Players", State.AimPlayers, function(v) State.AimPlayers = v; if v then State.AimMobs = false end end)
		AddToggle("Aim: Mobs", State.AimMobs, function(v) State.AimMobs = v; if v then State.AimPlayers = false end end)
		AddToggle("Smart ESP", State.ESP, function(v) State.ESP = v end)
		AddToggle("Anti-Stun (Fixed)", State.AntiStun, function(v) State.AntiStun = v end)
		
	elseif name == "Perf." then
		AddButton("Find Best Ping Server", function() ServerHop() end)
		AddToggle("Anti-Ban (30m Hop)", State.AntiBan, function(v) State.AntiBan = v; if v then Notify("Security Active") end end)
		AddToggle("High Performance", State.HighPerf, function(v)
			State.HighPerf = v
			if v then 
				setfpscap(30)
				Lighting.GlobalShadows = false 
				for _,v in pairs(workspace:GetDescendants()) do if v:IsA("BasePart") then v.Material = Enum.Material.SmoothPlastic end end
			else 
				setfpscap(999) 
				Lighting.GlobalShadows = true 
			end
		end)
	end
end

